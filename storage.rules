rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // firebase-config.js 의 ADMIN_EMAILS 와 동일한 이메일 목록으로 유지하세요.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email in ["mutsu34@gmail.com"];
    }

    match /ticket_images/{userId}/{ticketId}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 4 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // 행정법 자료실 PDF (관리자만 업로드·조회)
    match /hanlaw_library/{libraryId}/{fileName} {
      allow read: if isAdmin();
      allow write: if isAdmin()
        && request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType == "application/pdf";
      allow delete: if isAdmin();
    }
  }
}
