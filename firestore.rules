rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // firebase-config.js 의 ADMIN_EMAILS 와 동일하게 유지 (토큰 이메일은 소문자로 비교)
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in ["mutsu34@gmail.com"];
    }

    match /hanlaw_questions/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /hanlaw_tickets/{ticketId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      // message.size() = UTF-8 바이트. 클라이언트는 글자 수 8000자 한도 — 한글 위주면 바이트가 훨씬 큼.
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.type in ["report", "question", "promotion", "suggestion"]
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() < 32000;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /hanlaw_notifications/{notifId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // 무료/유료 구분. 문서 없음 = 무료. 유료 전환은 관리자만 쓰기(콘솔·웹훅 등).
    match /hanlaw_members/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if isAdmin();
    }

    // 질문권 지갑. 차감·지급은 Cloud Functions(Admin SDK)만 수행합니다.
    match /hanlaw_question_wallet/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // 출석 포인트(퀴즈 1문제 이상 풀이 시 일 1회 지급). 쓰기는 Functions만.
    match /hanlaw_attendance_rewards/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if false;

      // 포인트 내역(대시보드). append는 Cloud Functions만.
      match /point_log/{entryId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if false;
      }
    }

    // 퀴즈 AI 질문 일일 횟수(Functions만 쓰기). 본인 읽기 허용(남은 횟수 표시용).
    match /hanlaw_quiz_ai_usage/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // 엘리(AI) 질문권 지갑. 지급·차감은 Cloud Functions만.
    match /hanlaw_quiz_ai_wallet/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // 엘리(AI) 질문 내역(대시보드). 쓰기는 Functions만, 본인 읽기.
    match /hanlaw_quiz_ai_asks/{askId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // 사용자 닉네임(AI·관리자 호칭). 쓰기는 setUserNickname Callable만(클라이언트 직접 쓰기 불가).
    match /hanlaw_user_profiles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // 결제 피드백 멱등 처리(Functions 전용, 예: PayApp)
    match /hanlaw_webhook_events/{eventId} {
      allow read, write: if false;
    }

    // PortOne 결제 준비(금액·상품 검증용). 읽기·쓰기는 Cloud Functions(Admin SDK)만.
    match /hanlaw_portone_prepare/{paymentId} {
      allow read, write: if false;
    }

    // 용어·판례 사전(정적 JS + Firestore 확장). 읽기는 로그인 사용자, 쓰기는 관리자(앱 내 편집) 또는 Functions.
    match /hanlaw_dict_terms/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /hanlaw_dict_cases/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /hanlaw_dict_statutes/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // 자료실 메타(업로드·학습 상태). 쓰기는 Cloud Functions(Admin SDK)만.
    match /hanlaw_library_files/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // 헤더 명언(승인된 목록). 앱 상단 노출용 공개 읽기, 쓰기는 Functions만.
    match /hanlaw_header_quotes/{docId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // 명언 검수 대기. Functions만 읽기·쓰기.
    match /hanlaw_quote_staging/{id} {
      allow read, write: if false;
    }

    // 변호사 질문 공개 목록(질문 본문). communityVisible==false 이면 질문자·관리자만 읽기(타인은 Q&A 미노출).
    match /hanlaw_qa_public/{ticketId} {
      allow read: if isAdmin()
        || (request.auth != null && resource.data.askerUserId == request.auth.uid)
        || resource.data.communityVisible == true
        || !("communityVisible" in resource.data);
      allow create, update, delete: if isAdmin();
    }

    // Q&A 답변 열람 멱등 로그(Functions 전용)
    match /hanlaw_qa_view_logs/{id} {
      allow read, write: if false;
    }

    // 고객 문의 채팅(하단 채팅). 쓰기는 submitSupportChatMessage Callable만. 읽기는 본인 스레드 또는 익명 UUID 스레드.
    match /hanlaw_support_chat/{threadId} {
      allow read: if isAdmin()
        || (request.auth != null && threadId == "user_" + request.auth.uid)
        || threadId.matches("^anon_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$");
      allow write: if false;

      match /messages/{messageId} {
        allow read: if isAdmin()
          || (request.auth != null && threadId == "user_" + request.auth.uid)
          || threadId.matches("^anon_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$");
        allow write: if false;
      }
    }
  }
}
