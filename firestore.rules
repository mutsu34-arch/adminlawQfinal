rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // firebase-config.js 의 ADMIN_EMAILS 와 동일하게 유지
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email in ["mutsu34@gmail.com"];
    }

    match /hanlaw_questions/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /hanlaw_tickets/{ticketId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.type in ["report", "question", "promotion"]
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() < 9000;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /hanlaw_notifications/{notifId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // 무료/유료 구분. 문서 없음 = 무료. 유료 전환은 관리자만 쓰기(콘솔·웹훅 등).
    match /hanlaw_members/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if isAdmin();
    }

    // 질문권 지갑. 차감·지급은 Cloud Functions(Admin SDK)만 수행합니다.
    match /hanlaw_question_wallet/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // 출석 포인트(퀴즈 1문제 이상 풀이 시 일 1회 지급). 쓰기는 Functions만.
    match /hanlaw_attendance_rewards/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // 퀴즈 AI 질문 일일 횟수(Functions만 쓰기). 본인 읽기 허용(남은 횟수 표시용).
    match /hanlaw_quiz_ai_usage/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // 사용자 닉네임(AI·관리자 호칭). 쓰기는 setUserNickname Callable만(클라이언트 직접 쓰기 불가).
    match /hanlaw_user_profiles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // Creem 웹훅 멱등 처리(Functions 전용)
    match /hanlaw_webhook_events/{eventId} {
      allow read, write: if false;
    }

    // 용어·판례 사전(정적 JS + Firestore 확장). 쓰기는 Cloud Functions만.
    match /hanlaw_dict_terms/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    match /hanlaw_dict_cases/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // 자료실 메타(업로드·학습 상태). 쓰기는 Cloud Functions(Admin SDK)만.
    match /hanlaw_library_files/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
